generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")        // pooler (6543) + ?pgbouncer=true
  directUrl = env("POSTGRES_URL_NON_POOLING")   // direct (5432), НЕ pooler
}

model geo_styles {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(255)
  description String?
  code        String
  image       String   @db.VarChar(1024)
  created_at  DateTime @default(now()) @db.Timestamp(6)
}